  .dot-rouge { background: #e33; box-shadow: 0 0 6px #e33; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
