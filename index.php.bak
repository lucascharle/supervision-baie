<script>
<?php if ($page === 'dashboard'): ?>

function formatDate(str) {
    const d = new Date(str.replace(' ', 'T'));
    return d.toLocaleDateString('fr-FR') + ' ' + d.toLocaleTimeString('fr-FR');
}

function refreshData() {
    fetch('api/data.php')
        .then(r => r.json())
        .then(data => {
            const now = new Date();
            document.getElementById('last-update').textContent = 'derniere mise a jour : ' + now.toLocaleTimeString('fr-FR');

            const temp = data.temperature;
            if (temp) {
                document.getElementById('temp-valeur').textContent = temp.valeur + '°C';
                document.getElementById('temp-date').textContent = formatDate(temp.date_heure);
                document.getElementById('card-temp').className = 'card ' + (parseFloat(temp.valeur) > 35 || parseFloat(temp.valeur) < 10 ? 'rouge' : 'orange');
            }

            const ouv = data.ouverture;
            if (ouv) {
                const ouverte = ouv.valeur == 1;
                document.getElementById('baie-dot').className = 'dot ' + (ouverte ? 'dot-rouge' : 'dot-vert');
                document.getElementById('baie-statut').textContent = ouverte ? 'OUVERTE' : 'FERMEE';
                document.getElementById('baie-date').textContent = formatDate(ouv.date_heure);
                document.getElementById('card-baie').className = 'card ' + (ouverte ? 'rouge' : 'vert');
            }

            const nb = data.nb_alertes;
            document.getElementById('nb-alertes').textContent = nb;
            document.getElementById('card-alertes').className = 'card ' + (nb > 0 ? 'rouge' : 'vert');
            document.getElementById('alertes-label').textContent = nb > 0 ? 'Action requise' : 'Tout est normal';

            const tbody = document.getElementById('tbody-mesures');
            tbody.innerHTML = '';
            data.mesures.forEach(m => {
                let valeurHtml = '';
                if (m.type === 'temperature') {
                    const cls = parseFloat(m.valeur) > 35 ? 'badge-rouge' : (parseFloat(m.valeur) < 10 ? 'badge-orange' : 'badge-vert');
                    valeurHtml = '<span class="badge ' + cls + '">' + m.valeur + '°C</span>';
                } else {
                    const cls = m.valeur == 1 ? 'badge-rouge' : 'badge-vert';
                    valeurHtml = '<span class="badge ' + cls + '">' + (m.valeur == 1 ? 'Ouverte' : 'Fermee') + '</span>';
                }
                tbody.innerHTML += '<tr><td>' + m.id_mesure + '</td><td>' + m.emplacement + '</td><td>' + (m.type === 'temperature' ? 'Temperature' : 'Ouverture') + '</td><td>' + valeurHtml + '</td><td>' + formatDate(m.date_heure) + '</td></tr>';
            });

            const tbodyA = document.getElementById('tbody-alertes');
            tbodyA.innerHTML = '';
            if (data.alertes.length === 0) {
                tbodyA.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#aaa;padding:20px">Aucune alerte</td></tr>';
            } else {
                const types = { 'temperature_haute': 'Temperature haute', 'temperature_basse': 'Temperature basse', 'ouverture_baie': 'Ouverture baie' };
                data.alertes.forEach(a => {
                    const statutCls = a.statut === 'non_lu' ? 'badge-rouge' : 'badge-vert';
                    const btnLu = a.statut === 'non_lu'
                        ? '<form method="POST" style="display:inline"><input type="hidden" name="action" value="marquer_lu"><input type="hidden" name="id" value="' + a.id_alerte + '"><button type="submit" class="btn btn-vert btn-sm">Marquer lu</button></form>'
                        : '';
                    tbodyA.innerHTML += '<tr><td>' + a.id_alerte + '</td><td>' + (types[a.type] || a.type) + '</td><td>' + a.valeur + '</td><td>' + a.email + '</td><td><div class="statut-cell"><span class="badge ' + statutCls + '">' + a.statut + '</span>' + btnLu + '</div></td><td>' + formatDate(a.date_heure) + '</td></tr>';
                });
            }
        })
        .catch(err => console.log('Erreur AJAX:', err));
}

setInterval(refreshData, 5000);
refreshData();

<?php endif; ?>
</script>

<?php endif; ?>
</body>
</html>
