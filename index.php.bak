  .form-group input { padding: 9px 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
  .checkbox-group { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
  .refresh-indicator { font-size: 12px; color: #aaa; text-align: right; margin-bottom: 8px; }
  .statut-cell { display: flex; gap: 8px; align-items: center; }
</style>
