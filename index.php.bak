  .btn-rouge { background: #e33; color: #fff; }
  .btn-gray { background: #888; color: #fff; }
  .btn-sm { padding: 4px 10px; font-size: 12px; }
  table { width: 100%; border-collapse: collapse; font-size: 14px; }
  th { background: #f8f8f8; padding: 10px 14px; text-align: left; font-weight: 600; border-bottom: 2px solid #eee; }
  td { padding: 10px 14px; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
